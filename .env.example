# Backend
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=60
CORS_ORIGINS=http://localhost:3000

# Database (docker-compose uses its own env, but keep this for future tooling)
DATABASE_URL=postgresql://ai_agency_boss:ai_agency_boss_dev@localhost:5432/ai_agency_boss

# AI (local)
AI_MODEL_PATH=storage/models/llama3
AI_DEVICE=auto
AI_DTYPE=auto

# Image (local Stable Diffusion)
IMAGE_MODEL_PATH=storage/models/stable-diffusion
IMAGE_MODEL_TYPE=sd15
IMAGE_DEVICE=auto
IMAGE_DTYPE=auto
IMAGE_OUTPUT_DIR=storage/outputs
